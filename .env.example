# Supabase — public (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email
RESEND_API_KEY=

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# IP hashing salt — server only
IP_HASH_SALT=

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Privacy rights tokens (Law 2024/017) — server only.
# Optional: falls back to ADMIN_JWT_SECRET if unset.
PRIVACY_TOKEN_SECRET=

# Canonical site URL used in privacy confirmation links
NEXT_PUBLIC_SITE_URL=https://getkaru.io

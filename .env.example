# ─────────────────────────────────────────────────────────────────────────────
# Karu — Environment Variables
# Copy to .env (local) and set the same keys in Vercel for production.
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — NEVER expose to client (bypasses Row Level Security)
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Email log encryption ──────────────────────────────────────────────────────
# MUST be at least 64 hex characters (openssl rand -hex 32).
# Used to AES-encrypt stored email bodies in admin_email_log.
EMAIL_ENCRYPT_KEY=

# ── Admin auth ────────────────────────────────────────────────────────────────
# ADMIN_SECRET is the admin login password (compared directly, constant-time).
ADMIN_SECRET=
# ADMIN_JWT_SECRET signs the admin session JWT (openssl rand -hex 32).
ADMIN_JWT_SECRET=

# ── Privacy rights tokens (Law 2024/017) — server only ────────────────────────
# Set to a value DISTINCT from ADMIN_JWT_SECRET (openssl rand -hex 32).
# Falls back to ADMIN_JWT_SECRET if unset, but a separate secret is correct.
PRIVACY_TOKEN_SECRET=

# ── Security: IP hashing salt — server only ───────────────────────────────────
IP_HASH_SALT=

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# If unset, the CAPTCHA widget is skipped (graceful fallback).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Site config ───────────────────────────────────────────────────────────────
# Canonical site URL used in privacy confirmation links.
NEXT_PUBLIC_SITE_URL=https://getkaru.io

# ── Analytics (optional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── SEO (optional) ────────────────────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=

# ── Maintenance mode (optional) ───────────────────────────────────────────────
# Set to "true" to redirect all traffic to the maintenance page.
MAINTENANCE_MODE=

# CSRF: explicit comma-separated preview origins (no .vercel.app wildcard).
# e.g. ALLOWED_PREVIEW_ORIGINS=https://karu-git-feature.vercel.app
ALLOWED_PREVIEW_ORIGINS=

{
  "enabled": true,
  "name": "Security scan on dependency change",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": ["package.json", "package-lock.json"]
  },
  "then": {
    "type": "runCommand",
    "command": "npm audit --audit-level=moderate && echo 'Security audit passed ✓'"
  }
}
